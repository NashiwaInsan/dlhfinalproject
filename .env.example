# =====================================================================
# Salin file ini menjadi ".env" lalu sesuaikan bila perlu.
#   cp .env.example .env
# Catatan: faker dijalankan di HOST (laptop kamu), jadi pakai localhost.
#          Service di dalam Docker saling memanggil lewat nama service.
# =====================================================================

# ----- SQL Server (AdventureWorks2025) -----
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=sa
# Password SA wajib kompleks (>=8 char, huruf besar+kecil+angka+simbol)
MSSQL_PASSWORD=YourStrong!Passw0rd
MSSQL_DATABASE=AdventureWorks2025

# ----- Marketplace PostgreSQL -----
PG_HOST=localhost
PG_PORT=5432
PG_DB=marketplace_db
PG_USER=mkuser
PG_PASSWORD=mkpass123

# ----- Marketplace API (diakses faker dari host) -----
MARKETPLACE_API_URL=http://localhost:8000

# ----- Path lokal -----
WATCHED_EXCEL_PATH=./watched/excel

# ----- Kecepatan faker (detik). Kecilkan untuk demo cepat. -----
FAKER_ONLINE_INTERVAL=60
FAKER_REVIEW_INTERVAL=45
FAKER_EXCEL_INTERVAL=600
